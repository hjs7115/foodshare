# FoodShare Docker deployment environment
# Copy this file to .env.docker and change secrets before deploying.

# MySQL container mode
MYSQL_DATABASE=foodshare
MYSQL_USER=foodshare
MYSQL_PASSWORD=change-this-mysql-password
MYSQL_ROOT_PASSWORD=change-this-root-password

# RDS mode, used with docker-compose.rds.yml instead of the MySQL container.
# SPRING_DATASOURCE_URL=jdbc:mysql://your-rds-endpoint:3306/foodshare?serverTimezone=Asia/Seoul&characterEncoding=UTF-8&useSSL=false&allowPublicKeyRetrieval=true
# SPRING_DATASOURCE_USERNAME=foodshare
# SPRING_DATASOURCE_PASSWORD=change-this-rds-password

# Spring Boot secrets
APP_JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-characters
APP_ADMIN_TOKEN=change-this-admin-token
APP_FIREBASE_ENABLED=false
# To enable FCM server push, put the Firebase Admin JSON at ./secrets/firebase-service-account.json and set:
# APP_FIREBASE_ENABLED=true
# APP_FIREBASE_SERVICE_ACCOUNT=/run/secrets/firebase-service-account.json

# Email verification and password reset mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=

# Frontend build-time variables
# Use / when nginx reverse proxy serves frontend and backend on the same domain.
VITE_API_BASE_URL=/
VITE_FIREBASE_API_KEY=AIzaSyCJb7J--Z4oCbmLZFNFCS-sWxa87j9zmDY
